  "description": "Surat ini terdiri atas 21 ayat, termasuk golongan surat-surat Makkiyah, diturunkan sesudah surat Al A'laa. Surat ini dinamai Al Lail (malam), diambil dari perkataan Al Lail yang terdapat pada ayat pertama surat ini",
  "revelation_place": "meccan",
  "ayah_count": 21,
  "verses": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلَّيْلِ إِذَا يَغْشَىٰ",
      "transliteration": "Wal-laili iżā yagsyā."
    },
    {
      "ayah": 2,
      "text": "وَٱلنَّهَارِ إِذَا تَجَلَّىٰ",
      "transliteration": "Wan-nahāri iżā tajallā."
    },
    {
      "ayah": 3,
      "text": "وَمَا خَلَقَ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ",
      "transliteration": "Wa mā khalaqaż-żakara wal-unṡā."
    },
    {
      "ayah": 4,
      "text": "إِنَّ سَعْيَكُمْ لَشَتَّىٰ",
      "transliteration": "Inna sa‘yakum lasyattā."
    },
    {
      "ayah": 5,
      "text": "فَأَمَّا مَنْ أَعْطَىٰ وَٱتَّقَىٰ",
      "transliteration": "Fa ammā man a‘ṭā wattaqā."
    },
    {
      "ayah": 6,
      "text": "وَصَدَّقَ بِٱلْحُسْنَىٰ",
      "transliteration": "Wa ṣaddaqa bil-ḥusnā."
    },
    {
      "ayah": 7,
      "text": "فَسَنُيَسِّرُهُۥ لِلْيُسْرَىٰ",
      "transliteration": "Fa sanuyassiruhū lil-yusrā."
    },
    {
      "ayah": 8,
      "text": "وَأَمَّا مَنۢ بَخِلَ وَٱسْتَغْنَىٰ",
      "transliteration": "Wa ammā man bakhila wastagnā."
    },
    {
      "ayah": 9,
      "text": "وَكَذَّبَ بِٱلْحُسْنَىٰ",
      "transliteration": "Wa każżaba bil-ḥusnā."
    },
    {
      "ayah": 10,
      "text": "فَسَنُيَسِّرُهُۥ لِلْعُسْرَىٰ",
      "transliteration": "Fa sanuyassiruhū lil-‘usrā."
    },
    {
      "ayah": 11,
      "text": "وَمَا يُغْنِى عَنْهُ مَالُهُۥٓ إِذَا تَرَدَّىٰٓ",
      "transliteration": "Wa mā yugnī ‘anhu māluhū iżā taraddā."
    },
    {
      "ayah": 12,
      "text": "إِنَّ عَلَيْنَا لَلْهُدَىٰ",
      "transliteration": "Inna ‘alainā lal-hudā."
    },
    {
      "ayah": 13,
      "text": "وَإِنَّ لَنَا لَلْـَٔاخِرَةَ وَٱلْأُولَىٰ",
      "transliteration": "Wa inna lanā lal-ākhirata wal-ūlā."
    },
    {
      "ayah": 14,
      "text": "فَأَنذَرْتُكُمْ نَارًا تَلَظَّىٰ",
      "transliteration": "Fa anżartukum nāran talaẓẓā."
    },
    {
      "ayah": 15,
      "text": "لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى",
      "transliteration": "Lā yaṣlāhā illal-asyqā."
    },
    {
      "ayah": 16,
      "text": "ٱلَّذِى كَذَّبَ وَتَوَلَّىٰ",
      "transliteration": "Allażī każżaba wa tawallā."
    },
    {
      "ayah": 17,
      "text": "وَسَيُجَنَّبُهَا ٱلْأَتْقَى",
      "transliteration": "Wa sayujannabuhal-atqā."
    },
    {
      "ayah": 18,
      "text": "ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ",
      "transliteration": "Allażī yu'tī mālahū yatazakkā."
    },
    {
      "ayah": 19,
      "text": "وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٍ تُجْزَىٰٓ",
      "transliteration": "Wa mā li'aḥadin ‘indahū min ni‘matin tujzā."
    },
    {
      "ayah": 20,
      "text": "إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِّهِ ٱلْأَعْلَىٰ",
      "transliteration": "Illabtigā'a wajhi rabbihil-a‘lā."
    },
    {
      "ayah": 21,
      "text": "وَلَسَوْفَ يَرْضَىٰ",
      "transliteration": "Wa lasaufa yarḍā."
    }
  ],
