    },
    {
      "ayah": 8,
      "text": "ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ",
      "transliteration": "Ṡumma latus'alunna yauma'iżin ‘anin-na‘īm(i)."
