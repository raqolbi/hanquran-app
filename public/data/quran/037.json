{
  "id": 37,
  "name_ar": "الصافات",
  "name_simple": "As-Saaffaat",
  "name_en": "Those drawn up in Ranks",
  "meaning": "Barisan-Barisan",
  "description": "Surat Ash Shaaffaat terdiri atas 182 ayat termasuk golongan surat Makkiyyah diturunkan sesudah surat Al An'aam. Dinamai dengan Ash Shaaffaat (yang bershaf-shaf) ada hubungannya dengan perkataan Ash Shaaffaat yang terletak pada ayat permulaan surat ini yang mengemukakan bagaimana para malaikat yang berbaris di hadapan Tuhannya yang bersih jiwanya, tidak dapat digoda oleh syaitan. Hal ini hendaklah menjadi i'tibar bagi manusia dalam menghambakan dirinya kepada Allah.",
  "revelation_place": "meccan",
  "ayah_count": 182,
  "verses": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلصَّٰٓفَّٰتِ صَفًّا",
      "transliteration": "Waṣ-ṣāffāti ṣaffā(n)."
    },
    {
      "ayah": 2,
      "text": "فَٱلزَّٰجِرَٰتِ زَجْرًا",
      "transliteration": "Faz-zājirāti zajrā(n)."
    },
    {
      "ayah": 3,
      "text": "فَٱلتَّٰلِيَٰتِ ذِكْرًا",
      "transliteration": "Fat-tāliyāti żikrā(n)."
    },
    {
      "ayah": 4,
      "text": "إِنَّ إِلَٰهَكُمْ لَوَٰحِدٌ",
      "transliteration": "Inna ilāhakum lawāḥid(un)."
    },
    {
      "ayah": 5,
      "text": "رَّبُّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا وَرَبُّ ٱلْمَشَٰرِقِ",
      "transliteration": "Rabbus-samāwāti wal-arḍi wa mā bainahumā wa rabbul-masyāriq(i)."
    },
    {
      "ayah": 6,
      "text": "إِنَّا زَيَّنَّا ٱلسَّمَآءَ ٱلدُّنْيَا بِزِينَةٍ ٱلْكَوَاكِبِ",
      "transliteration": "Innā zayyannas-samā'ad-dun-yā bizīnatinil-kawākib(i)."
    },
    {
      "ayah": 7,
      "text": "وَحِفْظًا مِّن كُلِّ شَيْطَٰنٍ مَّارِدٍ",
      "transliteration": "Wa ḥifẓam min kulli syaiṭānim mārid(in)."
    },
    {
      "ayah": 8,
      "text": "لَّا يَسَّمَّعُونَ إِلَى ٱلْمَلَإِ ٱلْأَعْلَىٰ وَيُقْذَفُونَ مِن كُلِّ جَانِبٍ",
      "transliteration": "Lā yassammā‘ūna ilal-mala'il-a‘lā wa yuqżafūna min kulli jānib(in)."
    },
    {
      "ayah": 9,
      "text": "دُحُورًا ۖ وَلَهُمْ عَذَابٌ وَاصِبٌ",
      "transliteration": "Duḥūraw wa lahum ‘ażābuw wāṣib(un)."
    },
    {
      "ayah": 10,
      "text": "إِلَّا مَنْ خَطِفَ ٱلْخَطْفَةَ فَأَتْبَعَهُۥ شِهَابٌ ثَاقِبٌ",
      "transliteration": "Illā man khaṭifal-khaṭfata fa'atba‘ahū syihābun ṡāqib(un)."
    },
    {
      "ayah": 11,
      "text": "فَٱسْتَفْتِهِمْ أَهُمْ أَشَدُّ خَلْقًا أَم مَّنْ خَلَقْنَآ ۚ إِنَّا خَلَقْنَٰهُم مِّن طِينٍ لَّازِبٍۭ",
      "transliteration": "Fastaftihim ahum asyaddu khalqan am man khalaqnā, innā khalaqnāhum min ṭīnil lāzib(in)."
    },
    {
      "ayah": 12,
      "text": "بَلْ عَجِبْتَ وَيَسْخَرُونَ",
      "transliteration": "Bal ‘ajibta wa yaskharūn(a)."
    },
    {
      "ayah": 13,
      "text": "وَإِذَا ذُكِّرُوا۟ لَا يَذْكُرُونَ",
      "transliteration": "Wa iżā żukkirū lā yażkurūn(a)."
    },
    {
      "ayah": 14,
      "text": "وَإِذَا رَأَوْا۟ ءَايَةً يَسْتَسْخِرُونَ",
      "transliteration": "Wa iżā ra'au āyatay yastaskhirūn(a)."
    },
    {
      "ayah": 15,
      "text": "وَقَالُوٓا۟ إِنْ هَٰذَآ إِلَّا سِحْرٌ مُّبِينٌ",
      "transliteration": "Wa qālū in hāżā illā siḥrum mubīn(un)."
    },
    {
      "ayah": 16,
      "text": "أَءِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَٰمًا أَءِنَّا لَمَبْعُوثُونَ",
      "transliteration": "A'iżā mitnā wa kunnā turābaw wa ‘iẓāman a'innā lamab‘ūṡūn(a)."
    },
    {
      "ayah": 17,
      "text": "أَوَءَابَآؤُنَا ٱلْأَوَّلُونَ",
      "transliteration": "Awa ābā'unal-awwalūn(a)."
    },
    {
      "ayah": 18,
      "text": "قُلْ نَعَمْ وَأَنتُمْ دَٰخِرُونَ",
      "transliteration": "Qul na‘am wa antum dākhirūn(a)."
    },
    {
      "ayah": 19,
      "text": "فَإِنَّمَا هِىَ زَجْرَةٌ وَٰحِدَةٌ فَإِذَا هُمْ يَنظُرُونَ",
      "transliteration": "Fa'innamā hiya zajratuw wāḥidatun fa'iżā hum yanẓurūn(a)."
    },
    {
      "ayah": 20,
      "text": "وَقَالُوا۟ يَٰوَيْلَنَا هَٰذَا يَوْمُ ٱلدِّينِ",
      "transliteration": "Wa qālū yā wailanā hāżā yaumud-dīn(i)."
    },
    {
      "ayah": 21,
      "text": "هَٰذَا يَوْمُ ٱلْفَصْلِ ٱلَّذِى كُنتُم بِهِۦ تُكَذِّبُونَ",
      "transliteration": "Hāżā yaumul-faṣlil-lażī kuntum bihī tukażżibūn(a)."
    },
    {
      "ayah": 22,
      "text": "ٱحْشُرُوا۟ ٱلَّذِينَ ظَلَمُوا۟ وَأَزْوَٰجَهُمْ وَمَا كَانُوا۟ يَعْبُدُونَ",
      "transliteration": "Uḥsyurul-lażīna ẓalamū wa azwājahum wa mā kānū ya‘budūn(a)."
    },
    {
      "ayah": 23,
      "text": "مِن دُونِ ٱللَّهِ فَٱهْدُوهُمْ إِلَىٰ صِرَٰطِ ٱلْجَحِيمِ",
      "transliteration": "Min dūnillāhi fahdūhum ilā ṣirāṭil-jaḥīm(i)."
    },
    {
      "ayah": 24,
      "text": "وَقِفُوهُمْ ۖ إِنَّهُم مَّسْـُٔولُونَ",
      "transliteration": "Waqifūhum innahum mas'ūlūn(a)."
    },
    {
      "ayah": 25,
      "text": "مَا لَكُمْ لَا تَنَاصَرُونَ",
      "transliteration": "Mā lakum lā tanāṣarūn(a)."
    },
    {
      "ayah": 26,
      "text": "بَلْ هُمُ ٱلْيَوْمَ مُسْتَسْلِمُونَ",
      "transliteration": "Bal humul-yauma mustaslimūn(a)."
    },
    {
      "ayah": 27,
      "text": "وَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَسَآءَلُونَ",
      "transliteration": "Wa aqbala ba‘ḍuhum ‘alā ba‘ḍiy yatasā'alūn(a)."
    },
    {
      "ayah": 28,
      "text": "قَالُوٓا۟ إِنَّكُمْ كُنتُمْ تَأْتُونَنَا عَنِ ٱلْيَمِينِ",
      "transliteration": "Qālū innakum kuntum ta'tūnanā ‘anil-yamīn(i)."
    },
    {
      "ayah": 29,
      "text": "قَالُوا۟ بَل لَّمْ تَكُونُوا۟ مُؤْمِنِينَ",
      "transliteration": "Qālū bal lam takūnū mu'minīn(a)."
    },
    {
      "ayah": 30,
      "text": "وَمَا كَانَ لَنَا عَلَيْكُم مِّن سُلْطَٰنٍۭ ۖ بَلْ كُنتُمْ قَوْمًا طَٰغِينَ",
      "transliteration": "Wa mā kāna lanā ‘alaikum min sulṭān(in), bal kuntum qauman ṭāgīn(a)."
    },
    {
      "ayah": 31,
      "text": "فَحَقَّ عَلَيْنَا قَوْلُ رَبِّنَآ ۖ إِنَّا لَذَآئِقُونَ",
      "transliteration": "Fa ḥaqqa ‘alainā qaulu rabbinā, innā lażā'iqūn(a)."
    },
    {
      "ayah": 32,
      "text": "فَأَغْوَيْنَٰكُمْ إِنَّا كُنَّا غَٰوِينَ",
      "transliteration": "Fa agwainākum innā kunnā gāwīn(a)."
    },
    {
      "ayah": 33,
      "text": "فَإِنَّهُمْ يَوْمَئِذٍ فِى ٱلْعَذَابِ مُشْتَرِكُونَ",
      "transliteration": "Fa innahum yauma'iżin fil-‘ażābi musytarikūn(a)."
    },
    {
      "ayah": 34,
      "text": "إِنَّا كَذَٰلِكَ نَفْعَلُ بِٱلْمُجْرِمِينَ",
      "transliteration": "Innā każālika naf‘alu bil-mujrimīn(a)."
    },
    {
      "ayah": 35,
      "text": "إِنَّهُمْ كَانُوٓا۟ إِذَا قِيلَ لَهُمْ لَآ إِلَٰهَ إِلَّا ٱللَّهُ يَسْتَكْبِرُونَ",
      "transliteration": "Innahum kānū iżā qīla lahum lā ilāha illallāhu yastakbirūn(a)."
    },
    {
      "ayah": 36,
      "text": "وَيَقُولُونَ أَئِنَّا لَتَارِكُوٓا۟ ءَالِهَتِنَا لِشَاعِرٍ مَّجْنُونٍۭ",
      "transliteration": "Wa yaqūlūna a'innā latārikū ālihatinā lisyā‘irim majnūn(in)."
    },
    {
      "ayah": 37,
      "text": "بَلْ جَآءَ بِٱلْحَقِّ وَصَدَّقَ ٱلْمُرْسَلِينَ",
      "transliteration": "Bal jā'a bil-ḥaqqi wa ṣaddaqal-mursalīn(a)."
    },
    {
      "ayah": 38,
      "text": "إِنَّكُمْ لَذَآئِقُوا۟ ٱلْعَذَابِ ٱلْأَلِيمِ",
      "transliteration": "Innakum lażā'iqul-‘ażābil-alīm(i)."
    },
    {
      "ayah": 39,
      "text": "وَمَا تُجْزَوْنَ إِلَّا مَا كُنتُمْ تَعْمَلُونَ",
      "transliteration": "Wa mā tujzauna illā mā kuntum ta‘malūn(a)."
    },
    {
      "ayah": 40,
      "text": "إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ",
      "transliteration": "Illā ‘ibādallāhil-mukhlaṣīn(a)."
    },
    {
      "ayah": 41,
      "text": "أُو۟لَٰٓئِكَ لَهُمْ رِزْقٌ مَّعْلُومٌ",
      "transliteration": "Ulā'ika lahum rizqum ma‘lūm(un)."
    },
    {
      "ayah": 42,
      "text": "فَوَٰكِهُ ۖ وَهُم مُّكْرَمُونَ",
      "transliteration": "Fawākihu wa hum mukramūn(a)."
    },
    {
      "ayah": 43,
      "text": "فِى جَنَّٰتِ ٱلنَّعِيمِ",
      "transliteration": "Fī jannātin na‘īm(i)."
    },
    {
      "ayah": 44,
      "text": "عَلَىٰ سُرُرٍ مُّتَقَٰبِلِينَ",
      "transliteration": "‘Alā sururim mutaqābilīn(a)."
    },
    {
      "ayah": 45,
      "text": "يُطَافُ عَلَيْهِم بِكَأْسٍ مِّن مَّعِينٍۭ",
      "transliteration": "Yuṭāfu ‘alaihim bika'sim mim ma‘īn(in)."
    },
    {
      "ayah": 46,
      "text": "بَيْضَآءَ لَذَّةٍ لِّلشَّٰرِبِينَ",
      "transliteration": "Baiḍā'a lażżatil lisy-syāribīn(a)."
    },
    {
      "ayah": 47,
      "text": "لَا فِيهَا غَوْلٌ وَلَا هُمْ عَنْهَا يُنزَفُونَ",
      "transliteration": "Lā fīhā gauluw wa lā hum ‘anhā yunzafūn(a)."
    },
    {
      "ayah": 48,
      "text": "وَعِندَهُمْ قَٰصِرَٰتُ ٱلطَّرْفِ عِينٌ",
      "transliteration": "Wa ‘indahum qāṣirātuṭ-ṭarfi ‘īn(un)."
    },
    {
      "ayah": 49,
      "text": "كَأَنَّهُنَّ بَيْضٌ مَّكْنُونٌ",
      "transliteration": "Ka'annahum baiḍum maknūn(un)."
    },
    {
      "ayah": 50,
      "text": "فَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَسَآءَلُونَ",
      "transliteration": "Fa'aqbala ba‘ḍuhum ‘alā ba‘ḍiy yatasā'alūn(a)."
    },
    {
      "ayah": 51,
      "text": "قَالَ قَآئِلٌ مِّنْهُمْ إِنِّى كَانَ لِى قَرِينٌ",
      "transliteration": "Qāla qā'ilum minhum innī kāna lī qarīn(un)."
    },
    {
      "ayah": 52,
      "text": "يَقُولُ أَءِنَّكَ لَمِنَ ٱلْمُصَدِّقِينَ",
      "transliteration": "Yaqūlu a'innaka laminal-muṣaddiqīn(a)."
    },
    {
      "ayah": 53,
      "text": "أَءِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَٰمًا أَءِنَّا لَمَدِينُونَ",
      "transliteration": "A'iżā mitnā wa kunnā turāban a'innā lamadīnūn(a)."
    },
    {
      "ayah": 54,
      "text": "قَالَ هَلْ أَنتُم مُّطَّلِعُونَ",
      "transliteration": "Qāla hal antum muṭṭali‘ūn(a)."
    },
    {
      "ayah": 55,
      "text": "فَٱطَّلَعَ فَرَءَاهُ فِى سَوَآءِ ٱلْجَحِيمِ",
      "transliteration": "Faṭṭala‘a fa ra'āhu fī sawā'il-jaḥīm(i)."
    },
    {
      "ayah": 56,
      "text": "قَالَ تَٱللَّهِ إِن كِدتَّ لَتُرْدِينِ",
      "transliteration": "Qāla tallāhi in kitta laturdīn(i)."
    },
    {
      "ayah": 57,
      "text": "وَلَوْلَا نِعْمَةُ رَبِّى لَكُنتُ مِنَ ٱلْمُحْضَرِينَ",
      "transliteration": "Wa lau lā ni‘matu rabbī lakuntu minal-muḥḍarīn(a)."
    },
    {
      "ayah": 58,
      "text": "أَفَمَا نَحْنُ بِمَيِّتِينَ",
      "transliteration": "Afamā naḥnu bimayyitīn(a)."
    },
    {
      "ayah": 59,
      "text": "إِلَّا مَوْتَتَنَا ٱلْأُولَىٰ وَمَا نَحْنُ بِمُعَذَّبِينَ",
      "transliteration": "Illā mautatunal-ūlā wa mā naḥnu bimu‘ażżabīn(a)."
    },
    {
      "ayah": 60,
      "text": "إِنَّ هَٰذَا لَهُوَ ٱلْفَوْزُ ٱلْعَظِيمُ",
      "transliteration": "Inna hāżā lahuwal-fauzul-‘aẓīm(u)."
    },
    {
      "ayah": 61,
      "text": "لِمِثْلِ هَٰذَا فَلْيَعْمَلِ ٱلْعَٰمِلُونَ",
      "transliteration": "Limiṡli hāżā falya‘malil-‘āmilūn(a)."
    },
    {
      "ayah": 62,
      "text": "أَذَٰلِكَ خَيْرٌ نُّزُلًا أَمْ شَجَرَةُ ٱلزَّقُّومِ",
      "transliteration": "Ażālika khairun nuzulan am syajaratuz-zaqqūm(i)."
    },
    {
      "ayah": 63,
      "text": "إِنَّا جَعَلْنَٰهَا فِتْنَةً لِّلظَّٰلِمِينَ",
      "transliteration": "Innā ja‘alnāhā fitnatal liẓ-ẓālimīn(a)."
    },
    {
      "ayah": 64,
      "text": "إِنَّهَا شَجَرَةٌ تَخْرُجُ فِىٓ أَصْلِ ٱلْجَحِيمِ",
      "transliteration": "Innahā syajaratun takhruju fī aṣlil-jaḥīm(i)."
    },
    {
      "ayah": 65,
      "text": "طَلْعُهَا كَأَنَّهُۥ رُءُوسُ ٱلشَّيَٰطِينِ",
      "transliteration": "Ṭal‘uhā ka'annahū ru'ūsusy-syayāṭīn(i)."
    },
    {
      "ayah": 66,
      "text": "فَإِنَّهُمْ لَـَٔاكِلُونَ مِنْهَا فَمَالِـُٔونَ مِنْهَا ٱلْبُطُونَ",
      "transliteration": "Fa innahum la'ākilūna minhā fa māli'ūna minhal-buṭūn(a)."
    },
    {
      "ayah": 67,
      "text": "ثُمَّ إِنَّ لَهُمْ عَلَيْهَا لَشَوْبًا مِّنْ حَمِيمٍ",
      "transliteration": "Ṡumma inna lahum ‘alaihā lasyaubam min ḥamīm(in)."
    },
    {
      "ayah": 68,
      "text": "ثُمَّ إِنَّ مَرْجِعَهُمْ لَإِلَى ٱلْجَحِيمِ",
      "transliteration": "Ṡumma inna marji‘ahum la'ilal-jaḥīm(i)."
    },
    {
      "ayah": 69,
      "text": "إِنَّهُمْ أَلْفَوْا۟ ءَابَآءَهُمْ ضَآلِّينَ",
      "transliteration": "Innahum alfau ābā'ahum ḍāllīn(a)."
    },
    {
      "ayah": 70,
      "text": "فَهُمْ عَلَىٰٓ ءَاثَٰرِهِمْ يُهْرَعُونَ",
      "transliteration": "Fahum ‘alā āṡārihim yuhra‘ūn(a)."
    },
    {
      "ayah": 71,
      "text": "وَلَقَدْ ضَلَّ قَبْلَهُمْ أَكْثَرُ ٱلْأَوَّلِينَ",
      "transliteration": "Wa laqad ḍalla qablahum akṡarul-awwalīn(a)."
    },
    {
      "ayah": 72,
      "text": "وَلَقَدْ أَرْسَلْنَا فِيهِم مُّنذِرِينَ",
      "transliteration": "Wa laqad arsalnā fīhim munżirīn(a)."
    },
    {
      "ayah": 73,
      "text": "فَٱنظُرْ كَيْفَ كَانَ عَٰقِبَةُ ٱلْمُنذَرِينَ",
      "transliteration": "Fanẓur kaifa kāna ‘āqibatul-munżarīn(a)."
    },
    {
      "ayah": 74,
      "text": "إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ",
      "transliteration": "Illā ‘ibādallāhil-mukhlaṣīn(a)."
    },
    {
      "ayah": 75,
      "text": "وَلَقَدْ نَادَىٰنَا نُوحٌ فَلَنِعْمَ ٱلْمُجِيبُونَ",
      "transliteration": "Wa laqad nādānā nūḥun falani‘mal-mujībūn(a)."
    },
    {
      "ayah": 76,
      "text": "وَنَجَّيْنَٰهُ وَأَهْلَهُۥ مِنَ ٱلْكَرْبِ ٱلْعَظِيمِ",
      "transliteration": "Wa najjaināhu wa ahlahū minal-karbil-‘aẓīm(i)."
    },
    {
      "ayah": 77,
      "text": "وَجَعَلْنَا ذُرِّيَّتَهُۥ هُمُ ٱلْبَاقِينَ",
      "transliteration": "Wa ja‘alnā żurriyyatahū humul-bāqīn(a)."
    },
    {
      "ayah": 78,
      "text": "وَتَرَكْنَا عَلَيْهِ فِى ٱلْـَٔاخِرِينَ",
      "transliteration": "Wa taraknā ‘alaihi fil-ākhirīn(a)."
    },
    {
      "ayah": 79,
      "text": "سَلَٰمٌ عَلَىٰ نُوحٍ فِى ٱلْعَٰلَمِينَ",
      "transliteration": "Salāmun ‘alā nūḥin fil-‘ālamīn(a)."
    },
    {
      "ayah": 80,
      "text": "إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ",
      "transliteration": "Innā każālika najzil-muḥsinīn(a)."
    },
    {
      "ayah": 81,
      "text": "إِنَّهُۥ مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ",
      "transliteration": "Innahū min ‘ibādinal-mu'minīn(a)."
    },
    {
      "ayah": 82,
      "text": "ثُمَّ أَغْرَقْنَا ٱلْـَٔاخَرِينَ",
      "transliteration": "Ṡumma agraqnal-ākharīn(a)."
    },
    {
      "ayah": 83,
      "text": "وَإِنَّ مِن شِيعَتِهِۦ لَإِبْرَٰهِيمَ",
      "transliteration": "Wa inna min syī‘atihī la'ibrāhīm(a)."
    },
    {
      "ayah": 84,
      "text": "إِذْ جَآءَ رَبَّهُۥ بِقَلْبٍ سَلِيمٍ",
      "transliteration": "Iż jā'a rabbahū biqalbin salīm(in)."
    },
    {
      "ayah": 85,
      "text": "إِذْ قَالَ لِأَبِيهِ وَقَوْمِهِۦ مَاذَا تَعْبُدُونَ",
      "transliteration": "Iż qāla li'abīhi wa qaumihī māżā ta‘budūn(a)."
    },
    {
      "ayah": 86,
      "text": "أَئِفْكًا ءَالِهَةً دُونَ ٱللَّهِ تُرِيدُونَ",
      "transliteration": "A'ifkan ālihatan dūnallāhi turīdūn(a)."
    },
    {
      "ayah": 87,
      "text": "فَمَا ظَنُّكُم بِرَبِّ ٱلْعَٰلَمِينَ",
      "transliteration": "Famā ẓannukum birabbil-‘ālamīn(a)."
    },
    {
      "ayah": 88,
      "text": "فَنَظَرَ نَظْرَةً فِى ٱلنُّجُومِ",
      "transliteration": "Fa naẓara naẓratan fin-nujūm(i)."
    },
    {
      "ayah": 89,
      "text": "فَقَالَ إِنِّى سَقِيمٌ",
      "transliteration": "Fa qāla innī saqīm(un)."
    },
    {
      "ayah": 90,
      "text": "فَتَوَلَّوْا۟ عَنْهُ مُدْبِرِينَ",
      "transliteration": "Fa tawallau ‘anhu mudbirīn(a)."
    },
    {
      "ayah": 91,
      "text": "فَرَاغَ إِلَىٰٓ ءَالِهَتِهِمْ فَقَالَ أَلَا تَأْكُلُونَ",
      "transliteration": "Farāga ilā ālihatihim faqāla alā ta'kulūn(a)."
    },
    {
      "ayah": 92,
      "text": "مَا لَكُمْ لَا تَنطِقُونَ",
      "transliteration": "Mā lakum lā tanṭiqūn(a)."
    },
    {
      "ayah": 93,
      "text": "فَرَاغَ عَلَيْهِمْ ضَرْبًۢا بِٱلْيَمِينِ",
      "transliteration": "Farāga ‘alaihim ḍarbam bil-yamīn(i)."
    },
    {
      "ayah": 94,
      "text": "فَأَقْبَلُوٓا۟ إِلَيْهِ يَزِفُّونَ",
      "transliteration": "Fa aqbalū ilaihi yaziffūn(a)."
    },
    {
      "ayah": 95,
      "text": "قَالَ أَتَعْبُدُونَ مَا تَنْحِتُونَ",
      "transliteration": "Qāla ata‘budūna mā tanḥitūn(a)."
    },
    {
      "ayah": 96,
      "text": "وَٱللَّهُ خَلَقَكُمْ وَمَا تَعْمَلُونَ",
      "transliteration": "Wallāhu khalaqakum wa mā ta‘malūn(a)."
    },
    {
      "ayah": 97,
      "text": "قَالُوا۟ ٱبْنُوا۟ لَهُۥ بُنْيَٰنًا فَأَلْقُوهُ فِى ٱلْجَحِيمِ",
      "transliteration": "Qālubnū lahū bun-yānan fa'alqūhu fil-jaḥīm(i)."
    },
    {
      "ayah": 98,
      "text": "فَأَرَادُوا۟ بِهِۦ كَيْدًا فَجَعَلْنَٰهُمُ ٱلْأَسْفَلِينَ",
      "transliteration": "Fa arādū bihī kaidan faja‘alnāhumul-asfalīn(a)."
    },
    {
      "ayah": 99,
      "text": "وَقَالَ إِنِّى ذَاهِبٌ إِلَىٰ رَبِّى سَيَهْدِينِ",
      "transliteration": "Wa qāla innī żāhibun ilā rabbī sayahdīn(i)."
    },
    {
      "ayah": 100,
      "text": "رَبِّ هَبْ لِى مِنَ ٱلصَّٰلِحِينَ",
      "transliteration": "Rabbi hab lī minaṣ-ṣāliḥīn(a)."
    },
    {
      "ayah": 101,
      "text": "فَبَشَّرْنَٰهُ بِغُلَٰمٍ حَلِيمٍ",
      "transliteration": "Fa basysyarnāhu bigulāmin ḥalīm(in)."
    },
    {
      "ayah": 102,
      "text": "فَلَمَّا بَلَغَ مَعَهُ ٱلسَّعْىَ قَالَ يَٰبُنَىَّ إِنِّىٓ أَرَىٰ فِى ٱلْمَنَامِ أَنِّىٓ أَذْبَحُكَ فَٱنظُرْ مَاذَا تَرَىٰ ۚ قَالَ يَٰٓأَبَتِ ٱفْعَلْ مَا تُؤْمَرُ ۖ سَتَجِدُنِىٓ إِن شَآءَ ٱللَّهُ مِنَ ٱلصَّٰبِرِينَ",
      "transliteration": "Falammā balaga ma‘ahus-sa‘ya qāla yā bunayya innī arā fil-manāmi annī ażbaḥuka fanẓur māżā tarā, qāla yā abatif‘al mā tu'mar(u), satajidunī in syā'allāhu minaṣ-ṣābirīn(a)."
    },
    {
      "ayah": 103,
      "text": "فَلَمَّآ أَسْلَمَا وَتَلَّهُۥ لِلْجَبِينِ",
      "transliteration": "Falammā aslamā wa tallahū lil-jabīn(i)."
    },
    {
      "ayah": 104,
      "text": "وَنَٰدَيْنَٰهُ أَن يَٰٓإِبْرَٰهِيمُ",
      "transliteration": "Wa nādaināhu ay yā ibrāhīm(u)."
    },
    {
      "ayah": 105,
      "text": "قَدْ صَدَّقْتَ ٱلرُّءْيَآ ۚ إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ",
      "transliteration": "Qad ṣaddaqtar-ru'yā, innā każālika najzil-muḥsinīn(a)."
    },
    {
      "ayah": 106,
      "text": "إِنَّ هَٰذَا لَهُوَ ٱلْبَلَٰٓؤُا۟ ٱلْمُبِينُ",
      "transliteration": "Inna hāżā lahuwal-balā'ul-mubīn(u)."
    },
    {
      "ayah": 107,
      "text": "وَفَدَيْنَٰهُ بِذِبْحٍ عَظِيمٍ",
      "transliteration": "Wa fadaināhu biżibḥin ‘aẓīm(in)."
    },
    {
      "ayah": 108,
      "text": "وَتَرَكْنَا عَلَيْهِ فِى ٱلْـَٔاخِرِينَ",
      "transliteration": "Wa taraknā ‘alaihi fil-ākhirīn(a)."
    },
    {
      "ayah": 109,
      "text": "سَلَٰمٌ عَلَىٰٓ إِبْرَٰهِيمَ",
      "transliteration": "Salāmun ‘alā ibrāhīm(a)."
    },
    {
      "ayah": 110,
      "text": "كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ",
      "transliteration": "Każālika najzil-muḥsinīn(a)."
    },
    {
      "ayah": 111,
      "text": "إِنَّهُۥ مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ",
      "transliteration": "Innahū min ‘ibādinal-mu'minīn(a)."
    },
    {
      "ayah": 112,
      "text": "وَبَشَّرْنَٰهُ بِإِسْحَٰقَ نَبِيًّا مِّنَ ٱلصَّٰلِحِينَ",
      "transliteration": "Wa basysyarnāhu bi'isḥāqa nabiyyam minaṣ-ṣāliḥīn(a)."
    },
    {
      "ayah": 113,
      "text": "وَبَٰرَكْنَا عَلَيْهِ وَعَلَىٰٓ إِسْحَٰقَ ۚ وَمِن ذُرِّيَّتِهِمَا مُحْسِنٌ وَظَالِمٌ لِّنَفْسِهِۦ مُبِينٌ",
      "transliteration": "Wa bāraknā ‘alaihi wa ‘alā isḥāq(a), wa min żurriyyatihimā muḥsinuw wa ẓālimul linafsihī mubīn(un)."
    },
    {
      "ayah": 114,
      "text": "وَلَقَدْ مَنَنَّا عَلَىٰ مُوسَىٰ وَهَٰرُونَ",
      "transliteration": "Wa laqad manannā ‘alā mūsā wa hārūn(a)."
    },
    {
      "ayah": 115,
      "text": "وَنَجَّيْنَٰهُمَا وَقَوْمَهُمَا مِنَ ٱلْكَرْبِ ٱلْعَظِيمِ",
      "transliteration": "Wa najjaināhumā wa qaumahumā minal-karbil-‘aẓīm(i)."
    },
    {
      "ayah": 116,
      "text": "وَنَصَرْنَٰهُمْ فَكَانُوا۟ هُمُ ٱلْغَٰلِبِينَ",
      "transliteration": "Wa naṣarnāhum fakānū humul-gālibīn(a)."
    },
    {
      "ayah": 117,
      "text": "وَءَاتَيْنَٰهُمَا ٱلْكِتَٰبَ ٱلْمُسْتَبِينَ",
      "transliteration": "Wa ātaināhumal-kitābal-mustabīn(a)."
    },
    {
      "ayah": 118,
      "text": "وَهَدَيْنَٰهُمَا ٱلصِّرَٰطَ ٱلْمُسْتَقِيمَ",
      "transliteration": "Wa hadaināhumaṣ-ṣirāṭal-mustaqīm(a)."
    },
    {
      "ayah": 119,
      "text": "وَتَرَكْنَا عَلَيْهِمَا فِى ٱلْـَٔاخِرِينَ",
      "transliteration": "Wa taraknā ‘alaihimā fil-ākhirīn(a)."
    },
    {
      "ayah": 120,
      "text": "سَلَٰمٌ عَلَىٰ مُوسَىٰ وَهَٰرُونَ",
      "transliteration": "Salāmun ‘alā mūsā wa hārūn(a)."
    },
    {
      "ayah": 121,
      "text": "إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ",
      "transliteration": "Innā każālika najzil-muḥsinīn(a)."
    },
    {
      "ayah": 122,
      "text": "إِنَّهُمَا مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ",
      "transliteration": "Innahumā min ‘ibādinal-mu'minīn(a)."
    },
    {
      "ayah": 123,
      "text": "وَإِنَّ إِلْيَاسَ لَمِنَ ٱلْمُرْسَلِينَ",
      "transliteration": "Wa inna ilyāsa laminal-mursalīn(a)."
    },
    {
      "ayah": 124,
      "text": "إِذْ قَالَ لِقَوْمِهِۦٓ أَلَا تَتَّقُونَ",
      "transliteration": "Iż qāla liqaumihī alā tattaqūn(a)."
    },
    {
      "ayah": 125,
      "text": "أَتَدْعُونَ بَعْلًا وَتَذَرُونَ أَحْسَنَ ٱلْخَٰلِقِينَ",
      "transliteration": "Atad‘ūna ba‘law wa tażarūna aḥsanal-khāliqīn(a)."
    },
    {
      "ayah": 126,
      "text": "ٱللَّهَ رَبَّكُمْ وَرَبَّ ءَابَآئِكُمُ ٱلْأَوَّلِينَ",
      "transliteration": "Allāha rabbakum wa rabba ābā'ikumul-awwalīn(a)."
    },
    {
      "ayah": 127,
      "text": "فَكَذَّبُوهُ فَإِنَّهُمْ لَمُحْضَرُونَ",
      "transliteration": "Fakażżabūhu fa'innahum lamuḥḍarūn(a)."
    },
    {
      "ayah": 128,
      "text": "إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ",
      "transliteration": "Illā ‘ibādallāhil-mukhlaṣīn(a)."
    },
    {
      "ayah": 129,
      "text": "وَتَرَكْنَا عَلَيْهِ فِى ٱلْـَٔاخِرِينَ",
      "transliteration": "Wa taraknā ‘alaihi fil-ākhirīn(a)."
    },
    {
      "ayah": 130,
      "text": "سَلَٰمٌ عَلَىٰٓ إِلْ يَاسِينَ",
      "transliteration": "Salāmun ‘alā ilyāsīn(a)."
    },
    {
      "ayah": 131,
      "text": "إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ",
      "transliteration": "Innā każālika najzil-muḥsinīn(a)."
    },
    {
      "ayah": 132,
      "text": "إِنَّهُۥ مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ",
      "transliteration": "Innahū min ‘ibādinal-mu'minīn(a)."
    },
    {
      "ayah": 133,
      "text": "وَإِنَّ لُوطًا لَّمِنَ ٱلْمُرْسَلِينَ",
      "transliteration": "Wa inna lūṭal laminal-mursalīn(a)."
    },
    {
      "ayah": 134,
      "text": "إِذْ نَجَّيْنَٰهُ وَأَهْلَهُۥٓ أَجْمَعِينَ",
      "transliteration": "Iż najjaināhu wa ahlahū ajma‘īn(a)."
    },
    {
      "ayah": 135,
      "text": "إِلَّا عَجُوزًا فِى ٱلْغَٰبِرِينَ",
      "transliteration": "Illā ‘ajūzan fil-gābirīn(a)."
    },
    {
      "ayah": 136,
      "text": "ثُمَّ دَمَّرْنَا ٱلْـَٔاخَرِينَ",
      "transliteration": "Ṡumma dammarnal-ākharīn(a)."
    },
    {
      "ayah": 137,
      "text": "وَإِنَّكُمْ لَتَمُرُّونَ عَلَيْهِم مُّصْبِحِينَ",
      "transliteration": "Wa innakum latamurrūna ‘alaihim muṣbiḥīn(a)."
    },
    {
      "ayah": 138,
      "text": "وَبِٱلَّيْلِ ۗ أَفَلَا تَعْقِلُونَ",
      "transliteration": "Wa bil-lail(i), afalā ta‘qilūn(a)."
    },
    {
      "ayah": 139,
      "text": "وَإِنَّ يُونُسَ لَمِنَ ٱلْمُرْسَلِينَ",
      "transliteration": "Wa inna yūnusa laminal-mursalīn(a)."
    },
    {
      "ayah": 140,
      "text": "إِذْ أَبَقَ إِلَى ٱلْفُلْكِ ٱلْمَشْحُونِ",
      "transliteration": "Iż abaqa ilal-fulkil-masyḥūn(i)."
    },
    {
      "ayah": 141,
      "text": "فَسَاهَمَ فَكَانَ مِنَ ٱلْمُدْحَضِينَ",
      "transliteration": "Fa sāhama fakāna minal-mudḥaḍīn(a)."
    },
    {
      "ayah": 142,
      "text": "فَٱلْتَقَمَهُ ٱلْحُوتُ وَهُوَ مُلِيمٌ",
      "transliteration": "Faltaqamahul-ḥūtu wa huwa mulīm(un)."
    },
    {
      "ayah": 143,
      "text": "فَلَوْلَآ أَنَّهُۥ كَانَ مِنَ ٱلْمُسَبِّحِينَ",
      "transliteration": "Falau lā annahū kāna minal-musabbiḥīn(a)."
    },
    {
      "ayah": 144,
      "text": "لَلَبِثَ فِى بَطْنِهِۦٓ إِلَىٰ يَوْمِ يُبْعَثُونَ",
      "transliteration": "Lalabiṡa fī baṭnihī ilā yaumi yub‘aṡūn(a)."
    },
    {
      "ayah": 145,
      "text": "فَنَبَذْنَٰهُ بِٱلْعَرَآءِ وَهُوَ سَقِيمٌ",
      "transliteration": "Fa nabażnāhu bil-‘arā'i wa huwa saqīm(un)."
    },
    {
      "ayah": 146,
      "text": "وَأَنۢبَتْنَا عَلَيْهِ شَجَرَةً مِّن يَقْطِينٍ",
      "transliteration": "Wa ambatnā ‘alaihi syajaratam miy yaqṭīn(in)."
    },
    {
      "ayah": 147,
      "text": "وَأَرْسَلْنَٰهُ إِلَىٰ مِا۟ئَةِ أَلْفٍ أَوْ يَزِيدُونَ",
      "transliteration": "Wa arsalnāhu ilā mi'ati alfin au yazīdūn(a)."
    },
    {
      "ayah": 148,
      "text": "فَـَٔامَنُوا۟ فَمَتَّعْنَٰهُمْ إِلَىٰ حِينٍ",
      "transliteration": "Fa'āmanū famatta‘nāhum ilā ḥīn(in)."
    },
    {
      "ayah": 149,
      "text": "فَٱسْتَفْتِهِمْ أَلِرَبِّكَ ٱلْبَنَاتُ وَلَهُمُ ٱلْبَنُونَ",
      "transliteration": "Fastaftihim alirabbikal-banātu wa lahumul-banūn(a)."
    },
    {
      "ayah": 150,
      "text": "أَمْ خَلَقْنَا ٱلْمَلَٰٓئِكَةَ إِنَٰثًا وَهُمْ شَٰهِدُونَ",
      "transliteration": "Am khalaqnal-malā'ikata ināṡaw wa hum syāhidūn(a)."
    },
    {
      "ayah": 151,
      "text": "أَلَآ إِنَّهُم مِّنْ إِفْكِهِمْ لَيَقُولُونَ",
      "transliteration": "Alā innahum min ifkihim layaqūlūn(a)."
    },
    {
      "ayah": 152,
      "text": "وَلَدَ ٱللَّهُ وَإِنَّهُمْ لَكَٰذِبُونَ",
      "transliteration": "Waladallāh(u), wa innahum lakāżibūn(a)."
    },
    {
      "ayah": 153,
      "text": "أَصْطَفَى ٱلْبَنَاتِ عَلَى ٱلْبَنِينَ",
      "transliteration": "Aṣṭafal-banāti ‘alal-banīn(a)."
    },
    {
      "ayah": 154,
      "text": "مَا لَكُمْ كَيْفَ تَحْكُمُونَ",
      "transliteration": "Mā lakum, kaifa taḥkumūn(a)."
    },
    {
      "ayah": 155,
      "text": "أَفَلَا تَذَكَّرُونَ",
      "transliteration": "Afalā tażakkarūn(a)."
    },
    {
      "ayah": 156,
      "text": "أَمْ لَكُمْ سُلْطَٰنٌ مُّبِينٌ",
      "transliteration": "Am lakum sulṭānum mubīn(un)."
    },
    {
      "ayah": 157,
      "text": "فَأْتُوا۟ بِكِتَٰبِكُمْ إِن كُنتُمْ صَٰدِقِينَ",
      "transliteration": "Fa'tū bikitābikum in kuntum ṣādiqīn(a)."
    },
    {
      "ayah": 158,
      "text": "وَجَعَلُوا۟ بَيْنَهُۥ وَبَيْنَ ٱلْجِنَّةِ نَسَبًا ۚ وَلَقَدْ عَلِمَتِ ٱلْجِنَّةُ إِنَّهُمْ لَمُحْضَرُونَ",
      "transliteration": "Wa ja‘alū bainahū wa bainal-jinnati nasabā(n), wa laqad ‘alimatil-jinnatu innahum lamuḥḍarūn(a)."
    },
    {
      "ayah": 159,
      "text": "سُبْحَٰنَ ٱللَّهِ عَمَّا يَصِفُونَ",
      "transliteration": "Subḥānallāhi ‘ammā yaṣifūn(a)."
    },
    {
      "ayah": 160,
      "text": "إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ",
      "transliteration": "Illā ‘ibādallāhil-mukhlaṣīn(a)."
    },
    {
      "ayah": 161,
      "text": "فَإِنَّكُمْ وَمَا تَعْبُدُونَ",
      "transliteration": "Fa'innakum wa mā ta‘budūn(a)."
    },
    {
      "ayah": 162,
      "text": "مَآ أَنتُمْ عَلَيْهِ بِفَٰتِنِينَ",
      "transliteration": "Mā antum ‘alaihi bifātinīn(a)."
    },
    {
      "ayah": 163,
      "text": "إِلَّا مَنْ هُوَ صَالِ ٱلْجَحِيمِ",
      "transliteration": "Illā man huwa ṣālil-jaḥīm(i)."
    },
    {
      "ayah": 164,
      "text": "وَمَا مِنَّآ إِلَّا لَهُۥ مَقَامٌ مَّعْلُومٌ",
      "transliteration": "Wa mā minnā illā lahū maqāmum ma‘lūm(un)."
    },
    {
      "ayah": 165,
      "text": "وَإِنَّا لَنَحْنُ ٱلصَّآفُّونَ",
      "transliteration": "Wa innā lanaḥnuṣ-ṣāffūn(a)."
    },
    {
      "ayah": 166,
      "text": "وَإِنَّا لَنَحْنُ ٱلْمُسَبِّحُونَ",
      "transliteration": "Wa innā lanaḥnul-musabbiḥūn(a)."
    },
    {
      "ayah": 167,
      "text": "وَإِن كَانُوا۟ لَيَقُولُونَ",
      "transliteration": "Wa in kānū layaqūlūn(a)."
    },
    {
      "ayah": 168,
      "text": "لَوْ أَنَّ عِندَنَا ذِكْرًا مِّنَ ٱلْأَوَّلِينَ",
      "transliteration": "Lau anna ‘indanā żikram minal-awwalīn(a)."
    },
    {
      "ayah": 169,
      "text": "لَكُنَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ",
      "transliteration": "Lakunnā ‘ibādallāhil-mukhlaṣīn(a)."
    },
    {
      "ayah": 170,
      "text": "فَكَفَرُوا۟ بِهِۦ ۖ فَسَوْفَ يَعْلَمُونَ",
      "transliteration": "Fa kafarū bih(ī), fasaufa ya‘lamūn(a)."
    },
    {
      "ayah": 171,
      "text": "وَلَقَدْ سَبَقَتْ كَلِمَتُنَا لِعِبَادِنَا ٱلْمُرْسَلِينَ",
      "transliteration": "Wa laqad sabaqat kalimatunā li‘ibādinal-mursalīn(a)."
    },
    {
      "ayah": 172,
      "text": "إِنَّهُمْ لَهُمُ ٱلْمَنصُورُونَ",
      "transliteration": "Innahum lahumul-manṣūrūn(a)."
    },
    {
      "ayah": 173,
      "text": "وَإِنَّ جُندَنَا لَهُمُ ٱلْغَٰلِبُونَ",
      "transliteration": "Wa inna jundanā lahumul-gālibūn(a)."
    },
    {
      "ayah": 174,
      "text": "فَتَوَلَّ عَنْهُمْ حَتَّىٰ حِينٍ",
      "transliteration": "Fatawalla ‘anhum ḥattā ḥīn(in)."
    },
    {
      "ayah": 175,
      "text": "وَأَبْصِرْهُمْ فَسَوْفَ يُبْصِرُونَ",
      "transliteration": "Wa abṣirhum, fa saufa yubṣirūn(a)."
    },
    {
      "ayah": 176,
      "text": "أَفَبِعَذَابِنَا يَسْتَعْجِلُونَ",
      "transliteration": "Afabi‘ażābinā yasta‘jilūn(a)."
    },
    {
      "ayah": 177,
      "text": "فَإِذَا نَزَلَ بِسَاحَتِهِمْ فَسَآءَ صَبَاحُ ٱلْمُنذَرِينَ",
      "transliteration": "Fa iżā nazala bisāḥatihim fa sā'a ṣabāḥul-munżarīn(a)."
    },
    {
      "ayah": 178,
      "text": "وَتَوَلَّ عَنْهُمْ حَتَّىٰ حِينٍ",
      "transliteration": "Wa tawalla ‘anhum ḥattā ḥīn(in)."
    },
    {
      "ayah": 179,
      "text": "وَأَبْصِرْ فَسَوْفَ يُبْصِرُونَ",
      "transliteration": "Wa abṣir, fasaufa yubṣirūn(a)."
    },
    {
      "ayah": 180,
      "text": "سُبْحَٰنَ رَبِّكَ رَبِّ ٱلْعِزَّةِ عَمَّا يَصِفُونَ",
      "transliteration": "Subḥāna rabbika rabbil-‘izzati ‘ammā yaṣifūn(a)."
    },
    {
      "ayah": 181,
      "text": "وَسَلَٰمٌ عَلَى ٱلْمُرْسَلِينَ",
      "transliteration": "Wa salāmun ‘alal-mursalīn(a)."
    },
    {
      "ayah": 182,
      "text": "وَٱلْحَمْدُ لِلَّهِ رَبِّ ٱلْعَٰلَمِينَ",
      "transliteration": "Wal-ḥamdu lillāhi rabbil-‘ālamīn(a)."
    }
  ],
