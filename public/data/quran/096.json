      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱقْرَأْ بِٱسْمِ رَبِّكَ ٱلَّذِى خَلَقَ",
      "transliteration": "Iqra' bismi rabbikal-lażī khalaq(a)."
    },
    {
      "ayah": 2,
      "text": "خَلَقَ ٱلْإِنسَٰنَ مِنْ عَلَقٍ",
      "transliteration": "Khalaqal-insāna min ‘alaq(in)."
    },
    {
      "ayah": 3,
      "text": "ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ",
      "transliteration": "Iqra' wa rabbukal-akram(u)."
    },
    {
      "ayah": 4,
      "text": "ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ",
      "transliteration": "Allażī ‘allama bil-qalam(i)."
    },
    {
      "ayah": 5,
      "text": "عَلَّمَ ٱلْإِنسَٰنَ مَا لَمْ يَعْلَمْ",
      "transliteration": "‘Allamal-insāna mā lam ya‘lam."
    },
    {
      "ayah": 6,
      "text": "كَلَّآ إِنَّ ٱلْإِنسَٰنَ لَيَطْغَىٰٓ",
      "transliteration": "Kallā innal-insāna layaṭgā."
    },
    {
      "ayah": 7,
      "text": "أَن رَّءَاهُ ٱسْتَغْنَىٰٓ",
      "transliteration": "Ar ra'āhustagnā."
    },
    {
      "ayah": 8,
      "text": "إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجْعَىٰٓ",
      "transliteration": "Inna ilā rabbikar-ruj‘ā."
    },
    {
      "ayah": 9,
      "text": "أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ",
      "transliteration": "Ara'aital-lażī yanhā."
    },
    {
      "ayah": 10,
      "text": "عَبْدًا إِذَا صَلَّىٰٓ",
      "transliteration": "‘Abdan iżā ṣallā."
    },
    {
      "ayah": 11,
      "text": "أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ",
      "transliteration": "Ara'aita in kāna ‘alal-hudā."
    },
    {
      "ayah": 12,
      "text": "أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ",
      "transliteration": "Au amara bit-taqwā."
    },
    {
      "ayah": 13,
      "text": "أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ",
      "transliteration": "Ara'aita in każżaba wa tawallā."
    },
    {
      "ayah": 14,
      "text": "أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ",
      "transliteration": "Alam ya‘lam bi'annallāha yarā."
    },
    {
      "ayah": 15,
      "text": "كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ",
      "transliteration": "Kallā la'il lam yantah(i), lanasfa‘am bin-nāṣiyah(ti)."
    },
    {
