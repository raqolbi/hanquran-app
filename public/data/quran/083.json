{
  "id": 83,
  "name_ar": "المطففين",
  "name_simple": "Al-Mutaffifin",
  "name_en": "Defrauding",
  "meaning": "Orang-Orang Curang",
  "description": "Surat ini terdiri atas 36 ayat, termasuk golongan surat-surat Makkiyyah, diturunkan sesudah surat Al 'Ankabuut dan merupakan surat yang terakhir di Mekkah sebelum hijrah. Al Muthaffifiin yang dijadikan nama bagi surat ini diambil dari kata Al Muthaffifiin yang terdapat pada ayat pertama.",
  "revelation_place": "meccan",
  "ayah_count": 36,
  "verses": [
    {
      "ayah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَيْلٌ لِّلْمُطَفِّفِينَ",
      "transliteration": "Wailul lil-muṭaffifīn(a)."
    },
    {
      "ayah": 2,
      "text": "ٱلَّذِينَ إِذَا ٱكْتَالُوا۟ عَلَى ٱلنَّاسِ يَسْتَوْفُونَ",
      "transliteration": "Allażīna iżaktālū ‘alan-nāsi yastaufūn(a)."
    },
    {
      "ayah": 3,
      "text": "وَإِذَا كَالُوهُمْ أَو وَّزَنُوهُمْ يُخْسِرُونَ",
      "transliteration": "Wa iżā kālūhum au wazanūhum yukhsirūn(a)."
    },
    {
      "ayah": 4,
      "text": "أَلَا يَظُنُّ أُو۟لَٰٓئِكَ أَنَّهُم مَّبْعُوثُونَ",
      "transliteration": "Alā yaẓunnu ulā'ika annahum mab‘ūṡūn(a)."
    },
    {
      "ayah": 5,
      "text": "لِيَوْمٍ عَظِيمٍ",
      "transliteration": "Liyaumin ‘aẓīm(in)."
    },
    {
      "ayah": 6,
      "text": "يَوْمَ يَقُومُ ٱلنَّاسُ لِرَبِّ ٱلْعَٰلَمِينَ",
      "transliteration": "Yauma yaqūmun-nāsu lirabbil-‘ālamīn(a)."
    },
    {
      "ayah": 7,
      "text": "كَلَّآ إِنَّ كِتَٰبَ ٱلْفُجَّارِ لَفِى سِجِّينٍ",
      "transliteration": "Kallā inna kitābal-fujjāri lafī sijjīn(in)."
    },
    {
      "ayah": 8,
      "text": "وَمَآ أَدْرَىٰكَ مَا سِجِّينٌ",
      "transliteration": "Wa mā adrāka mā sijjīn(un)."
    },
    {
      "ayah": 9,
      "text": "كِتَٰبٌ مَّرْقُومٌ",
      "transliteration": "Kitābum marqūm(un)."
    },
    {
      "ayah": 10,
      "text": "وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ",
      "transliteration": "Wailuy yauma'iżil lil-mukażżibīn(a)."
    },
    {
      "ayah": 11,
      "text": "ٱلَّذِينَ يُكَذِّبُونَ بِيَوْمِ ٱلدِّينِ",
      "transliteration": "Allażīna yukażżibūna biyaumid-dīn(i)."
    },
    {
      "ayah": 12,
      "text": "وَمَا يُكَذِّبُ بِهِۦٓ إِلَّا كُلُّ مُعْتَدٍ أَثِيمٍ",
      "transliteration": "Wa mā yukażżibu bihī illā kullu mu‘tadin aṡīm(in)."
    },
    {
      "ayah": 13,
      "text": "إِذَا تُتْلَىٰ عَلَيْهِ ءَايَٰتُنَا قَالَ أَسَٰطِيرُ ٱلْأَوَّلِينَ",
      "transliteration": "Iżā tutlā ‘alaihi āyātunā qāla asāṭīrul-awwalīn(a)."
    },
    {
      "ayah": 14,
      "text": "كَلَّا ۖ بَلْ ۜ رَانَ عَلَىٰ قُلُوبِهِم مَّا كَانُوا۟ يَكْسِبُونَ",
      "transliteration": "Kallā bal…rāna ‘alā qulūbihim mā kānū yaksibūn(a)."
    },
    {
      "ayah": 15,
      "text": "كَلَّآ إِنَّهُمْ عَن رَّبِّهِمْ يَوْمَئِذٍ لَّمَحْجُوبُونَ",
      "transliteration": "Kallā innahum ‘ar rabbihim yauma'iżil lamaḥjūbūn(a)."
    },
    {
      "ayah": 16,
      "text": "ثُمَّ إِنَّهُمْ لَصَالُوا۟ ٱلْجَحِيمِ",
      "transliteration": "Ṡumma innahum laṣālul-jaḥīm(i)."
    },
    {
      "ayah": 17,
      "text": "ثُمَّ يُقَالُ هَٰذَا ٱلَّذِى كُنتُم بِهِۦ تُكَذِّبُونَ",
      "transliteration": "Ṡumma yuqālu hāżal-lażī kuntum bihī tukażżibūn(a)."
    },
    {
      "ayah": 18,
      "text": "كَلَّآ إِنَّ كِتَٰبَ ٱلْأَبْرَارِ لَفِى عِلِّيِّينَ",
      "transliteration": "Kallā inna kitābal-abrāri lafī ‘illiyyīn(a)."
    },
    {
      "ayah": 19,
      "text": "وَمَآ أَدْرَىٰكَ مَا عِلِّيُّونَ",
      "transliteration": "Wa mā adrāka mā ‘illiyyūn(a)."
    },
    {
      "ayah": 20,
      "text": "كِتَٰبٌ مَّرْقُومٌ",
      "transliteration": "Kitābum marqūm(un)."
    },
    {
      "ayah": 21,
      "text": "يَشْهَدُهُ ٱلْمُقَرَّبُونَ",
      "transliteration": "Yasyhaduhul-muqarrabūn(a)."
    },
    {
      "ayah": 22,
      "text": "إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍ",
      "transliteration": "Innal-abrāra lafī na‘īm(in)."
    },
    {
      "ayah": 23,
      "text": "عَلَى ٱلْأَرَآئِكِ يَنظُرُونَ",
      "transliteration": "‘Alal-arā'iki yanẓurūn(a)."
    },
    {
      "ayah": 24,
      "text": "تَعْرِفُ فِى وُجُوهِهِمْ نَضْرَةَ ٱلنَّعِيمِ",
      "transliteration": "Ta‘rifu fī wujūhihim naḍratan na‘īm(i)."
    },
    {
      "ayah": 25,
      "text": "يُسْقَوْنَ مِن رَّحِيقٍ مَّخْتُومٍ",
      "transliteration": "Yusqauna mir raḥīqim makhtūm(in)."
    },
    {
      "ayah": 26,
      "text": "خِتَٰمُهُۥ مِسْكٌ ۚ وَفِى ذَٰلِكَ فَلْيَتَنَافَسِ ٱلْمُتَنَٰفِسُونَ",
      "transliteration": "Khitāmuhū misk(un), wa fī żālika falyatanāfasil-mutanāfisūn(a)."
    },
    {
      "ayah": 27,
      "text": "وَمِزَاجُهُۥ مِن تَسْنِيمٍ",
      "transliteration": "Wa mizājuhū min tasnīm(in)."
    },
    {
      "ayah": 28,
      "text": "عَيْنًا يَشْرَبُ بِهَا ٱلْمُقَرَّبُونَ",
      "transliteration": "‘Ainay yasyrabu bihal-muqarrabūn(a)."
    },
    {
      "ayah": 29,
      "text": "إِنَّ ٱلَّذِينَ أَجْرَمُوا۟ كَانُوا۟ مِنَ ٱلَّذِينَ ءَامَنُوا۟ يَضْحَكُونَ",
      "transliteration": "Innal-lażīna ajramū kānū minal-lażīna āmanū yaḍḥakūn(a)."
    },
    {
      "ayah": 30,
      "text": "وَإِذَا مَرُّوا۟ بِهِمْ يَتَغَامَزُونَ",
      "transliteration": "Wa iżā marrū bihim yatagāmazūn(a)."
    },
    {
      "ayah": 31,
      "text": "وَإِذَا ٱنقَلَبُوٓا۟ إِلَىٰٓ أَهْلِهِمُ ٱنقَلَبُوا۟ فَكِهِينَ",
      "transliteration": "Wa iżanqalabū ilā ahlihimunqalabū fakihīn(a)."
    },
    {
      "ayah": 32,
      "text": "وَإِذَا رَأَوْهُمْ قَالُوٓا۟ إِنَّ هَٰٓؤُلَآءِ لَضَآلُّونَ",
      "transliteration": "Wa iżā ra'auhum qālū inna hā'ulā'i laḍāllūn(a)."
    },
    {
      "ayah": 33,
      "text": "وَمَآ أُرْسِلُوا۟ عَلَيْهِمْ حَٰفِظِينَ",
      "transliteration": "Wa mā ursilū ‘alaihim ḥāfiẓīn(a)."
    },
    {
      "ayah": 34,
      "text": "فَٱلْيَوْمَ ٱلَّذِينَ ءَامَنُوا۟ مِنَ ٱلْكُفَّارِ يَضْحَكُونَ",
      "transliteration": "Fal-yaumal-lażīna āmanū minal kuffāri yaḍḥakūn(a)."
    },
    {
      "ayah": 35,
      "text": "عَلَى ٱلْأَرَآئِكِ يَنظُرُونَ",
      "transliteration": "‘Alal-arā'iki yanẓurūn(a)."
    },
    {
      "ayah": 36,
      "text": "هَلْ ثُوِّبَ ٱلْكُفَّارُ مَا كَانُوا۟ يَفْعَلُونَ",
      "transliteration": "Hal ṡuwwibal-kuffāru mā kānū yaf‘alūn(a)."
    }
  ],
